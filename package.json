{
  "name": "uxpdebugger",
  "displayName": "UXP Debugger",
  "description": "Attach to Adobe UXP plugins for debugging in VSCode. Supports inlined sourcemaps",
  "version": "0.2.0",
  "author": "Jaroslav Bereza",
  "publisher": "JaroslavBereza",
  "pricing": "Free",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jardicc/vscode-uxp-debugger"
  },
  "categories": [
    "Debuggers"
  ],
  "keywords": [
    "uxp",
    "adobe",
    "photoshop",
    "indesign",
    "debugger",
    "plugin",
    "cdp",
    "chrome devtools protocol",
    "UXP Developer Tools",
    "UDT"
  ],
  "activationEvents": [
    "onDebugResolve:uxp",
    "onCommand:uxp.attach",
    "onCommand:uxp.patchAsar"
  ],
  "main": "./dist/extension.js",
  "icon": "./resources/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "uxp.attach",
        "title": "UXP: Attach to Adobe UXP Plugin"
      },
      {
        "command": "uxp.patchAsar",
        "title": "UXP: Patch app.asar (Persist .uxprc)"
      }
    ],
    "debuggers": [
      {
        "type": "uxp",
        "label": "UXP Debug",
        "configurationAttributes": {
          "attach": {
            "required": [],
            "properties": {
              "manifestPath": {
                "type": "string",
                "description": "Absolute path to the plugin's manifest.json. Supports VS Code variables like ${workspaceFolder}.",
                "default": "${workspaceFolder}/manifest.json"
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "UXP: Attach to Plugin",
            "description": "Attach to a running Adobe UXP plugin. Place a .debug.json or .uxprc file next to manifest.json for endpoint discovery.",
            "body": {
              "type": "uxp",
              "request": "attach",
              "name": "Attach to UXP Plugin",
              "manifestPath": "^\"\\${workspaceFolder}/manifest.json\""
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "UXP Debugger",
      "properties": {
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "lint": "eslint src --ext ts",
    "build": "vsce package",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}
